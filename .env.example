# Косинусное расстояние для кластеризации (default 0.2, меньше → больше кластеров)
CLUSTERIZE_DISTANCE_THRESHOLD=0.2

# Косинусное расстояние для дедупликации обогащённых имён (default 0.15)
ENRICHED_DEDUP_THRESHOLD=0.15

# Для g4f
G4F_MODEL=gpt-4
G4F_WEB_SEARCH=true

# Для Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite
# Отдельная модель для векторизации (не отображается в дашборде Flash Lite)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Google Search в запросах Gemini (доп. квота); по умолчанию выключено
GEMINI_WEB_SEARCH=false

REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Лимиты LLM: кластеризация batch=18, нормализация batch=8, пауза 4с между запросами
# При 429: до 3 попыток с паузами 15/30/45 с (база × номер попытки)
LLM_BATCH_SIZE=18
LLM_NORMALIZE_BATCH_SIZE=8
LLM_REQUEST_DELAY_SECONDS=4
LLM_RATE_LIMIT_RETRY_SECONDS=15
LLM_MAX_RETRIES=3
